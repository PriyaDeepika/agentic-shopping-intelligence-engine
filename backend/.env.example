# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- LLM provider: "openai" | "gemini" | "mock" ---
# "mock" runs fully offline with deterministic responses — useful for demos/tests.
LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Embeddings: "local" (sentence-transformers, no API key) | "openai" ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Storage ---
POSTGRES_DSN=postgresql+asyncpg://ase:ase@localhost:5432/ase
REDIS_URL=redis://localhost:6379/0
PRODUCTS_PATH=data/products.json
FAISS_INDEX_PATH=data/faiss.index
MEMORY_TTL_SECONDS=15552000

# --- Observability ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-shopping-engine
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- API ---
# "*" (default) works for local dev. In production, set explicit origins,
# e.g. CORS_ORIGINS=https://your-frontend.com,https://www.your-frontend.com
# For local dev against the included Next.js frontend (npm run dev, port 3000):
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
